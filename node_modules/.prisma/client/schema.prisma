// This is a copy of the main app's schema.
// Keep them in sync, or use a shared package.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String?           @unique
  emailVerified DateTime?
  image         String?
  phone         String?           @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  accounts      Account[]
  sessions      Session[]
  groups        GroupMembership[]
  events        DetectedEvent[]
  subscription  Subscription?
  calendarLinks CalendarLink[]
}

model WhatsAppGroup {
  id              String            @id @default(cuid())
  whatsappGroupId String            @unique
  name            String
  description     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  members         GroupMembership[]
  messages        WhatsAppMessage[]
  events          DetectedEvent[]
}

model GroupMembership {
  id          String        @id @default(cuid())
  userId      String
  groupId     String
  isActive    Boolean       @default(true)
  isMonitored Boolean       @default(false)
  mutedAt     DateTime?
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  group       WhatsAppGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model WhatsAppMessage {
  id          String          @id @default(cuid())
  waMessageId String          @unique
  groupId     String
  senderPhone String
  senderName  String?
  content     String          @db.Text
  timestamp   DateTime
  processed   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  group       WhatsAppGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  events      DetectedEvent[]
}

model DetectedEvent {
  id          String           @id @default(cuid())
  userId      String
  groupId     String
  messageId   String?
  title       String
  description String?          @db.Text
  startTime   DateTime
  endTime     DateTime?
  location    String?
  eventType   EventType        @default(REMINDER)
  confidence  Float            @default(0.8)
  status      EventStatus      @default(PENDING)
  calendarId  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  group       WhatsAppGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  message     WhatsAppMessage? @relation(fields: [messageId], references: [id])
}

model CalendarLink {
  id           String           @id @default(cuid())
  userId       String
  provider     CalendarProvider
  accessToken  String?          @db.Text
  refreshToken String?          @db.Text
  expiresAt    DateTime?
  calendarId   String?
  calendarName String?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique
  stripeCustomerId String?            @unique
  stripePriceId    String?
  stripeSubId      String?            @unique
  status           SubscriptionStatus @default(FREE)
  currentPeriodEnd DateTime?
  cancelAtEnd      Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum EventType {
  SCHOOL_EVENT
  DEADLINE
  BRING_ITEM
  MEETING
  TRIP
  PAYMENT
  REMINDER
  OTHER
}

enum EventStatus {
  PENDING
  SYNCED
  DISMISSED
  FAILED
}

enum CalendarProvider {
  GOOGLE
  APPLE
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  PAST_DUE
  CANCELED
}
