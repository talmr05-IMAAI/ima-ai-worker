# Same database as the main app
DATABASE_URL="postgresql://user:password@localhost:5432/groupcal"

# Anthropic API key (same as main app)
ANTHROPIC_API_KEY=""

# Shared secret so the Next.js app can talk to this worker
WORKER_API_SECRET="generate-a-random-secret-here"

# URL of your Next.js frontend (for CORS)
FRONTEND_URL="http://localhost:3000"

# Port for this worker
PORT=3001
